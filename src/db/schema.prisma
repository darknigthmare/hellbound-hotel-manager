datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Character {
  id             String   @id @default(uuid())
  name           String
  alias          String
  type           String   // 'sinner', 'hellborn', 'angel', 'fallen_angel', 'overlord', 'redeemed_soul', 'unknown'
  role           String   // 'founder', 'manager', 'resident', 'bartender', 'housekeeper', 'sponsor', 'security', 'antagonist', 'ally', 'external'
  status         String   // 'staff', 'resident', 'applicant', 'banned', 'redeemed', 'external', 'deceased', 'unknown'
  riskLevel      String   // 'low', 'medium', 'high', 'catastrophic'
  charlieTrust   Int      // 0 to 100
  rehabProgress  Int      // 0 to 100
  contracts      String   // Comma-separated or JSON list of active contracts
  notes          String
  canonStatus    String   // 'canon', 'semi_canon', 'user_note', 'headcanon', 'unknown'
  timelineScope  String   // 'pilot_legacy', 'season_1_start', 'season_1_end', 'season_2', 'custom'
  sourceRef      String
  spoilerLevel   String   // 'none', 'season_1', 'season_2', 'future'
  description    String
}

model Room {
  number             String   @id
  floor              Int
  type               String   // 'standard', 'suite', 'staff_room', 'secured_room', 'damaged_room', 'restricted'
  occupantId         String?  // References Character.id
  capacity           Int
  status             String   // 'clean', 'messy', 'damaged', 'cursed', 'under_repair', 'locked'
  dangerLevel        String   // 'low', 'medium', 'high', 'catastrophic'
  restrictions       String   // Comma-separated or JSON list
  maintenanceNotes   String
  repairCost         Float
  lastInspectionDate String
  lastInspectedBy    String?
}

model RehabilitationPlan {
  id                     String   @id @default(uuid())
  characterId            String   @unique
  goals                  String   // JSON list
  obstacles              String   // JSON list
  triggers               String   // JSON list
  empathyScore           Int      // 0 to 100
  accountabilityScore    Int      // 0 to 100
  impulseControlScore    Int      // 0 to 100
  cooperationScore       Int      // 0 to 100
  charlieNotes           String
  vaggieNotes            String
  staffPrivateNotes      String
  isRedeemedConfirmed    Boolean  @default(false)
}

model RehabilitationSession {
  id                      String   @id @default(uuid())
  planId                  String
  date                    String
  type                    String   // 'accountability_session', 'empathy_workshop', etc.
  summary                 String
  empathyDelta            Int
  accountabilityDelta     Int
  impulseControlDelta     Int
  cooperationDelta        Int
  conductedBy             String   // References Character.id
}

model Incident {
  id                String   @id @default(uuid())
  date              String
  location          String
  residentsInvolved String   // Comma-separated or JSON list of Character.id
  type              String   // 'violence', 'property_damage', 'media_scandal', etc.
  severity          String   // 'low', 'medium', 'high', 'crisis'
  summary           String
  consequences      String
  repairCost        Float
  reputationImpact  Int
  trustImpact       Int
  actionTaken       String
  status            String   // 'open', 'contained', 'resolved', 'archived'
  loreLink          String?  // References LoreEntry.id
  tags              String   // Comma-separated tags
}

model StaffTask {
  id             String   @id @default(uuid())
  date           String
  title          String
  type           String   // 'room_inspection', 'conflict_resolution', etc.
  assignedTo     String   // References Character.id
  mentalWorkload Int      // 1 to 10
  status         String   // 'pending', 'in_progress', 'completed', 'cancelled'
  notes          String
}

model ReputationState {
  id                    Int      @id @default(1)
  sinnerReputation      Int      // 0 to 100
  redemptionCredibility Int      // 0 to 100
  internalTrust         Int      // 0 to 100
  heavenAttention       Int      // 0 to 100
  overlordHostility     Int      // 0 to 100
  veesInfluence         Int      // 0 to 100
  mediaChaos            Int      // 0 to 100
}

model LoreEntry {
  id            String   @id @default(uuid())
  title         String
  entityName    String
  category      String   // 'character', 'faction', 'location', 'event', etc.
  description   String
  canonStatus   String   // 'canon', 'semi_canon', 'user_note', 'headcanon', 'unknown'
  sourceType    String   // 'episode', 'official_page', 'creator_statement', etc.
  sourceRef     String
  spoilerLevel  String   // 'none', 'season_1', 'season_2', 'future'
  timelineScope String   // 'pilot_legacy', 'season_1_start', 'season_1_end', 'season_2', 'custom'
  isLocked      Boolean  @default(false)
}

model Faction {
  id          String   @id
  name        String
  description String
  influence   Int      // 0 to 100
}

model Relationship {
  id        String   @id @default(uuid())
  charAId   String
  charBId   String
  type      String   // 'ally', 'enemy', 'contract_bound', etc.
  notes     String
}

model ResourceLedger {
  id          String   @id @default(uuid())
  date        String
  type        String   // 'income', 'expense'
  category    String   // 'repair', 'food_beverage', etc.
  amount      Float
  description String
}

model AuditLog {
  id        String   @id @default(uuid())
  timestamp String
  action    String
  details   String
}

model AppSettings {
  id                    Int      @id @default(1)
  appName               String
  randomEventsEnabled   Boolean  @default(true)
  theme                 String
}
